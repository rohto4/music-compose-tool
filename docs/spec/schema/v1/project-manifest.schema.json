{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://music-compose-tool.invalid/schema/v1/project-manifest.schema.json",
  "title": "Music Compose Tool Project Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "formatVersion",
    "projectId",
    "title",
    "revision",
    "savedRevision",
    "createdAt",
    "updatedAt",
    "entryMode",
    "creativeIntent",
    "musicalGrid",
    "arrangement",
    "melody",
    "tracks",
    "hummingTakes",
    "assetRefs",
    "generationCandidates",
    "loop"
  ],
  "properties": {
    "formatVersion": { "const": "1.0.0" },
    "projectId": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "revision": { "type": "integer", "minimum": 0 },
    "savedRevision": { "type": ["integer", "null"], "minimum": 0 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "entryMode": { "enum": ["patchboard", "humming-studio"] },
    "creativeIntent": { "$ref": "#/$defs/creativeIntent" },
    "musicalGrid": { "$ref": "#/$defs/musicalGrid" },
    "arrangement": { "$ref": "#/$defs/arrangement" },
    "melody": { "$ref": "#/$defs/melody" },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": { "$ref": "#/$defs/track" }
    },
    "hummingTakes": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/hummingTake" }
    },
    "assetRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "generationCandidates": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/generationCandidate" }
    },
    "loop": { "$ref": "#/$defs/loop" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "creativeIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["genre", "mood", "targetDurationSeconds", "freeText", "spokenIntentAssetId", "referenceAssetIds"],
      "properties": {
        "genre": { "enum": ["cute-future-bass", "cute-future-core"] },
        "mood": { "type": "array", "maxItems": 16, "items": { "type": "string", "maxLength": 64 } },
        "targetDurationSeconds": { "type": "number", "minimum": 10, "maximum": 600 },
        "freeText": { "type": "string", "maxLength": 4000 },
        "spokenIntentAssetId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "referenceAssetIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
      }
    },
    "musicalGrid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ppq", "bpm", "meter", "key"],
      "properties": {
        "ppq": { "const": 480 },
        "bpm": { "type": "number", "minimum": 30, "maximum": 300 },
        "meter": { "enum": ["2/4", "3/4", "4/4", "6/8"] },
        "key": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "arrangement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceAssetId", "sections"],
      "properties": {
        "sourceAssetId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "sections": { "type": "array", "minItems": 1, "maxItems": 128, "items": { "$ref": "#/$defs/section" } }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "label", "startBar", "bars", "energyStart", "energyEnd", "transitionAssetId"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "role": { "enum": ["intro", "verse", "build", "drop", "break", "bridge", "outro", "custom"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "startBar": { "type": "integer", "minimum": 0 },
        "bars": { "type": "integer", "minimum": 1, "maximum": 512 },
        "energyStart": { "type": "number", "minimum": 0, "maximum": 1 },
        "energyEnd": { "type": "number", "minimum": 0, "maximum": 1 },
        "transitionAssetId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] }
      }
    },
    "melody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "trackId", "laneId", "lockPitch", "lockTiming", "activeTakeId"],
      "properties": {
        "source": { "$ref": "#/$defs/noteSource" },
        "trackId": { "$ref": "#/$defs/id" },
        "laneId": { "$ref": "#/$defs/id" },
        "lockPitch": { "type": "boolean" },
        "lockTiming": { "type": "boolean" },
        "activeTakeId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] }
      }
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "name", "color", "instrumentId", "muted", "solo", "volume", "pan", "fx", "lanes", "automation"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "role": { "enum": ["melody", "chord", "drum", "bass", "lead", "synth", "pad", "arp", "percussion", "fx", "transition", "audio", "reference"] },
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "instrumentId": { "$ref": "#/$defs/id" },
        "muted": { "type": "boolean" },
        "solo": { "type": "boolean" },
        "volume": { "type": "number", "minimum": 0, "maximum": 1.5 },
        "pan": { "type": "number", "minimum": -1, "maximum": 1 },
        "fx": { "$ref": "#/$defs/fx" },
        "lanes": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/lane" } },
        "automation": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/automationLane" } }
      }
    },
    "fx": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filter", "reverb", "delay", "sidechain"],
      "properties": {
        "filter": { "type": "number", "minimum": 0, "maximum": 1 },
        "reverb": { "type": "number", "minimum": 0, "maximum": 1 },
        "delay": { "type": "number", "minimum": 0, "maximum": 1 },
        "sidechain": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role", "kind", "muted", "notes", "blocks", "audioClips"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "role": { "enum": ["main", "sub", "take"] },
        "kind": { "enum": ["notes", "drums", "audio"] },
        "muted": { "type": "boolean" },
        "notes": { "type": "array", "maxItems": 100000, "items": { "$ref": "#/$defs/note" } },
        "blocks": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/musicBlock" } },
        "audioClips": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/audioClip" } }
      }
    },
    "noteSource": { "enum": ["humming", "generated", "manual", "asset", "midi-input"] },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "pitch", "startTick", "durationTick", "velocity", "source", "confidence", "userEdited", "lockPitch", "lockTiming"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "pitch": { "type": "integer", "minimum": 0, "maximum": 127 },
        "startTick": { "type": "integer", "minimum": 0 },
        "durationTick": { "type": "integer", "minimum": 1 },
        "velocity": { "type": "integer", "minimum": 1, "maximum": 127 },
        "source": { "$ref": "#/$defs/noteSource" },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "userEdited": { "type": "boolean" },
        "lockPitch": { "type": "boolean" },
        "lockTiming": { "type": "boolean" }
      }
    },
    "musicBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "assetId", "startTick", "durationTick", "granularity", "parentBlockId"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "assetId": { "$ref": "#/$defs/id" },
        "startTick": { "type": "integer", "minimum": 0 },
        "durationTick": { "type": "integer", "minimum": 1 },
        "granularity": { "enum": ["draft", "shape", "detail"] },
        "parentBlockId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] }
      }
    },
    "audioClip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "assetId", "startTick", "durationTick", "offsetSeconds", "gain"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "assetId": { "$ref": "#/$defs/id" },
        "startTick": { "type": "integer", "minimum": 0 },
        "durationTick": { "type": "integer", "minimum": 1 },
        "offsetSeconds": { "type": "number", "minimum": 0 },
        "gain": { "type": "number", "minimum": 0, "maximum": 4 }
      }
    },
    "automationLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "parameter", "enabled", "points"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "parameter": { "enum": ["volume", "pan", "filter", "reverb", "delay", "sidechain"] },
        "enabled": { "type": "boolean" },
        "points": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/automationPoint" } }
      }
    },
    "automationPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tick", "value", "curve"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "tick": { "type": "integer", "minimum": 0 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "curve": { "enum": ["linear", "step"] }
      }
    },
    "hummingTake": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "assetId", "label", "recordedAt", "durationSeconds", "targetSectionId", "rangeStartTick", "rangeEndTick", "status", "selected", "transcribedNotes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "assetId": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "recordedAt": { "type": "string", "format": "date-time" },
        "durationSeconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 30 },
        "targetSectionId": { "$ref": "#/$defs/id" },
        "rangeStartTick": { "type": "integer", "minimum": 0 },
        "rangeEndTick": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["recorded", "transcribing", "ready", "failed"] },
        "selected": { "type": "boolean" },
        "transcribedNotes": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/note" } }
      }
    },
    "generationCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "capability", "status", "model", "modelRevision", "seed", "outputAssetId", "inputAssetIds", "intentTrace", "createdAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "capability": { "enum": ["humming-transcription", "accompaniment", "loop-fx", "asset-retrieval", "repaint"] },
        "status": { "enum": ["queued", "running", "succeeded", "failed", "rejected", "expired"] },
        "model": { "type": ["string", "null"], "maxLength": 160 },
        "modelRevision": { "type": ["string", "null"], "maxLength": 160 },
        "seed": { "type": ["integer", "null"] },
        "outputAssetId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "inputAssetIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "intentTrace": { "type": "array", "uniqueItems": true, "items": { "type": "string", "maxLength": 240 } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "startTick", "endTick"],
      "properties": {
        "enabled": { "type": "boolean" },
        "startTick": { "type": "integer", "minimum": 0 },
        "endTick": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
