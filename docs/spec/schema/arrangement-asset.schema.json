{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://music-compose-tool.invalid/schema/arrangement-asset.schema.json",
  "title": "Music Compose Tool Arrangement Asset",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "assetId", "label", "genre", "lengthBars", "sections", "slots"],
  "properties": {
    "formatVersion": { "const": "0.1.0" },
    "assetId": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1, "maxLength": 100 },
    "genre": { "enum": ["cute-future-bass", "cute-future-core"] },
    "lengthBars": { "type": "integer", "minimum": 1, "maximum": 512 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "bars", "energyStart", "energyEnd", "transition"],
        "properties": {
          "role": { "enum": ["intro", "verse", "build", "drop", "break", "bridge", "outro", "custom"] },
          "bars": { "type": "integer", "minimum": 1, "maximum": 128 },
          "energyStart": { "type": "number", "minimum": 0, "maximum": 1 },
          "energyEnd": { "type": "number", "minimum": 0, "maximum": 1 },
          "transition": { "enum": ["none", "riser", "fill", "silence-cut", "impact", "custom"] }
        }
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "required", "tags"],
        "properties": {
          "role": { "enum": ["melody", "chord", "drum", "bass", "synth", "fx"] },
          "required": { "type": "boolean" },
          "tags": { "type": "array", "items": { "type": "string", "maxLength": 64 }, "uniqueItems": true }
        }
      }
    }
  }
}
